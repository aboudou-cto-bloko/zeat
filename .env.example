# Convex – récupérer depuis https://dashboard.convex.dev après `pnpm convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex Auth – générer avec : openssl rand -base64 64 | tr -d '\n'
JWKS=
JWT_PRIVATE_KEY=

# Resend – https://resend.com/api-keys
RESEND_API_KEY=

# Email de notification des commandes
RESTAURANT_NOTIFICATION_EMAIL=

NEXT_PUBLIC_CONVEX_SITE_URL=

# VAPID – générer avec : pnpm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Upstash Redis – https://console.upstash.com (optionnel en dev, requis en prod pour le rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
